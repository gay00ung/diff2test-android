#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ $# -eq 0 ]]; then
  exec "$SCRIPT_DIR/gradlew" :apps:cli:run
fi

ARGS=""
for arg in "$@"; do
  if [[ -n "$ARGS" ]]; then
    ARGS+=" "
  fi
  ARGS+="$arg"
done

exec "$SCRIPT_DIR/gradlew" :apps:cli:run --args="$ARGS"
